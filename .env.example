# ============================================================================
# llm-server configuration
# ============================================================================

# LiteLLM master key — generate with:
#   python3 -c "import secrets; print('sk-' + secrets.token_urlsafe(32))"
LITELLM_MASTER_KEY=sk-CHANGE-ME

# Data root — where Ollama models, Open WebUI state, and Caddy certs live.
#   AWS / bare metal:  ./data            (relative to compose file)
#   RunPod:            /runpod-volume    (Network Volume mount path)
#   or any absolute path
DATA_ROOT=./data

# Caddy site address — determines how Caddy serves:
#   :80                          HTTP only (behind RunPod proxy / ALB / Cloudflare)
#   llm.example.com              public domain with auto Let's Encrypt cert
SITE_ADDRESS=:80

# Host ports Caddy binds to. On RunPod expose these in the pod template.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Models to pre-pull on first boot (space-separated Ollama tags)
MODELS=gemma4:e4b

# Open WebUI auth on/off
WEBUI_AUTH=True

# Optional: real Anthropic key for claude-* pass-through (unused in current config)
ANTHROPIC_API_KEY=
